# OpenAI API Configuration
# ⚠️ QUAN TRỌNG: Đừng chia sẻ API key của bạn!
# 1. Lấy API key từ https://platform.openai.com/api/keys
# 2. Tạo file .env (copy từ .env.example)
# 3. Dán API key vào OPENAI_API_KEY=sk-... (chỉ cục bộ, KHÔNG commit lên GitHub)
OPENAI_API_KEY=sk-your-api-key-here

# Optional: Customize model and parameters
OPENAI_MODEL=gpt-3.5-turbo
MAX_TOKENS=250
TEMPERATURE=0.5

# Server configuration
PORT=3000
NODE_ENV=development

